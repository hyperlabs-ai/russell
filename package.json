{
  "name": "russell-monorepo",
  "private": true,
  "description": "Russell — a declarative language for conversational agents. Monorepo: @hyperlabs-ai/russell-schema + @hyperlabs-ai/russell-validator",
  "license": "MIT",
  "author": "Hyperlabs AI <cris@hyperdigital.mx>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hyperlabs-ai/russell.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "test": "npm run test --workspaces --if-present",
    "validate:examples": "node packages/validator/dist/cli.js validate examples/dory.russell.json"
  },
  "engines": {
    "node": ">=20"
  }
}
