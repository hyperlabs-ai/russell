{
  "name": "russell-schema",
  "version": "0.2.0",
  "description": "Russell agent format: JSON Schema for declarative conversational agents, node type catalog, and TypeScript types",
  "license": "MIT",
  "author": "Hyperlabs AI <cris@hyperdigital.mx>",
  "homepage": "https://github.com/hyperlabs-ai/russell#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hyperlabs-ai/russell.git",
    "directory": "packages/schema"
  },
  "bugs": {
    "url": "https://github.com/hyperlabs-ai/russell/issues"
  },
  "keywords": [
    "russell",
    "agents",
    "conversational-agents",
    "declarative",
    "json-schema",
    "llm",
    "hyperflow"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schemas/russell.schema.json": "./schemas/russell.schema.json",
    "./schemas/node-types.json": "./schemas/node-types.json"
  },
  "files": [
    "dist",
    "schemas"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "~5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
