{
  "name": "@hyperlabs-ai/russell-validator",
  "version": "0.1.0",
  "description": "Validator and CLI for Russell agent definitions: structural (JSON Schema) + semantic (graph integrity, node type catalog, per-type params)",
  "license": "MIT",
  "author": "Hyperlabs AI <cris@hyperdigital.mx>",
  "homepage": "https://github.com/hyperlabs-ai/russell#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hyperlabs-ai/russell.git",
    "directory": "packages/validator"
  },
  "bugs": {
    "url": "https://github.com/hyperlabs-ai/russell/issues"
  },
  "keywords": [
    "russell",
    "agents",
    "conversational-agents",
    "validator",
    "cli",
    "llm",
    "hyperflow"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "russell": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@hyperlabs-ai/russell-schema": "0.1.0",
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "~5.9.3",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
