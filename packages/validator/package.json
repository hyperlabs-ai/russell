{
  "name": "@russell/validator",
  "version": "0.1.0",
  "description": "Validador de definiciones de agente Russell (estructura + integridad de grafo + catálogo de nodos)",
  "license": "MIT",
  "keywords": ["russell", "agents", "validator", "hyperflow"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "russell": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@russell/schema": "0.1.0",
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "~5.9.3",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
